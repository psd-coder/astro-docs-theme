<script is:inline>
  function applyCurrentTheme(root) {
    var setting = localStorage.getItem("theme") || "auto";
    var dark =
      setting === "dark" ||
      (setting === "auto" && matchMedia("(prefers-color-scheme: dark)").matches);
    root.dataset.theme = dark ? "dark" : "light";
    root.dataset.themeSetting = setting;
  }
  applyCurrentTheme(document.documentElement);
  // Apply to the incoming document before swap so ClientRouter's attribute merge
  // preserves data-theme and avoids a flash to the opposite color scheme.
  document.addEventListener("astro:before-swap", function (e) {
    applyCurrentTheme(e.newDocument.documentElement);
  });
</script>
